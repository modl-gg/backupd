# Required
MONGODB_URI="mongodb://username:password@mongo-host:27017/?authSource=admin"
BACKBLAZE_KEY_ID=""
BACKBLAZE_APPLICATION_KEY=""
BACKUP_ENCRYPTION_PASSPHRASE=""

# Backblaze B2
BACKBLAZE_ENDPOINT="https://s3.us-east-005.backblazeb2.com"
BACKBLAZE_REGION=""
BACKBLAZE_BUCKET_NAME="modl-database-backups"

# Backup behavior
BACKUP_PREFIX="mongo-backups"
BACKUP_INTERVAL_SECONDS="10800"
BACKUP_RETENTION_COUNT="12"
BACKUP_OPLOG_MODE="auto"
BACKUP_MAX_RUNTIME_SECONDS="7200"
BACKUP_RUN_ON_START="false"

# Advanced tuning
BACKUP_MULTIPART_PART_SIZE_BYTES="8388608"
BACKUP_ENCRYPTION_CHUNK_SIZE_BYTES="1048576"

# Logging
BACKUP_LOG_FORMAT="json"
RUST_LOG="info"

# Optional Discord alerting
DISCORD_WEBHOOK_URL=""
DISCORD_ROLE_MENTION=""
